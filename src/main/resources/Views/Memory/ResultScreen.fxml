                                <Font size="18.0" />
                            </font>
                        </Label>
                        <Label alignment="CENTER" prefHeight="25.0" prefWidth="800.0" text="Result Screen" />
                    </children>
                </VBox>
            </children>
        </VBox>
        <Pane prefHeight="516.0" prefWidth="800.0" AnchorPane.topAnchor="100.0">
            <children>
                <VBox layoutX="209.0" layoutY="100.0" prefHeight="321.0" prefWidth="382.0" styleClass="box">
