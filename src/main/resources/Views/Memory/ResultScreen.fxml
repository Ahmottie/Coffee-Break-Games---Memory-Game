                                <Label fx:id="deckSizeLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="57.0" prefWidth="223.0" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                <Label text="Match Size" GridPane.rowIndex="4" />
                                <Label fx:id="matchSizeLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="48.0" prefWidth="251.0" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4">
