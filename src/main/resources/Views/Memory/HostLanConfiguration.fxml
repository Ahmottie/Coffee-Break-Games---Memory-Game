                          </font>
                  </Label>
                      <Label alignment="CENTER" prefHeight="25.0" prefWidth="800.0" text="Host Game Setup" />
               </children>
            </VBox>
                <AnchorPane prefHeight="520.0" prefWidth="800.0">
                    <children>
                  <GridPane layoutX="225.0" layoutY="100.0" prefHeight="168.0" prefWidth="350.0" styleClass="box">
